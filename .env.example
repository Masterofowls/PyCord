# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,pycord.fly.dev
CSRF_TRUSTED_ORIGINS=https://pycord.fly.dev

# Database — Supabase Postgres or Turso/libSQL via service-urls
# Format: postgres://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgres://postgres:password@localhost:5432/pycord
# DATABASE_URL=postgres://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Realtime channel layer (set USE_REDIS=True for production)
USE_REDIS=False
REDIS_URL=redis://localhost:6379/0

# Email (allauth verification, password reset)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=PyCord <noreply@pycord.fly.dev>

# GitHub OAuth — create at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Passkeys / WebAuthn relying party
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=PyCord

# Media / static
MEDIA_ROOT=./media
